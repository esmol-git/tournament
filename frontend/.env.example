# Public API origin (no trailing slash). Override for staging/production.
NUXT_PUBLIC_API_BASE=http://localhost:4000

# Локально против удалённого API: браузер → http://localhost:3000/__remote-api (не 127.0.0.1!), Nitro проксирует на NUXT_REMOTE_API_TARGET.
# NUXT_PUBLIC_API_BASE=http://localhost:3000/__remote-api
# NUXT_REMOTE_API_TARGET=https://api.tournament-platform.ru

# Slug тенанта для /auth/login, если не пришёл из публичного сайта (стор пустой).
NUXT_PUBLIC_DEFAULT_TENANT_SLUG=default

