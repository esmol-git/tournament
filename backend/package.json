    "start:debug": "nest start --debug --watch",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "bootstrap:super-admin": "ts-node src/scripts/bootstrap-super-admin.ts",
    "seed:ci-playwright": "ts-node src/scripts/seed-ci-playwright-users.ts",
    "smoke:playoff": "ts-node src/scripts/smoke-playoff-propagation.ts",
    "smoke:playoff:heavy": "SMOKE_PLAYOFF_SIZES=32,128,256 npm run smoke:playoff",
    "smoke:formats": "ts-node src/scripts/smoke-tournament-formats.ts",
    "seed:load-large": "ts-node src/scripts/seed-large-load.ts",
    "seed:world-cup-like": "ts-node src/scripts/seed-world-cup-like.ts",
    "seed:tournament-results": "ts-node src/scripts/seed-tournament-results.ts",
    "seed:spanish-cup-like": "ts-node src/scripts/seed-spanish-cup-like.ts",
    "seed:tenant-teams-players": "ts-node src/scripts/seed-tenant-teams-players.ts",
    "seed:tenant-teams-players:prod": "node dist/scripts/seed-tenant-teams-players.js",
    "cleanup:tenant-seed-batch": "ts-node src/scripts/cleanup-tenant-seed-batch.ts",
    "cleanup:tenant-seed-batch:prod": "node dist/scripts/cleanup-tenant-seed-batch.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "6.4.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "6.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
