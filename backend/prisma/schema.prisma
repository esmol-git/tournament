generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  // Отдельная БД для shadow (migrate dev), если у роли нет права CREATEDB (ошибка P3014).
  // Создай вручную: CREATE DATABASE tournament_shadow;
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  blocked     Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  /** Тариф (лимиты, что показывать в UI). */
  subscriptionPlan SubscriptionPlan @default(FREE)
  /** Жизненный цикл подписки в биллинге. */
  subscriptionStatus SubscriptionStatus @default(NONE)
  /**
   * Доступ по подписке/оплате до этой даты (UTC).
   * `null` — без дедлайна (например FREE, ручной доступ, «вечный» договор).
   */
  subscriptionEndsAt DateTime?
  /** Id клиента в платёжной системе (Stripe Customer и т.д.) — по мере интеграции. */
  billingCustomerId String?
  /** Id подписки во внешней системе — по мере интеграции. */
  billingSubscriptionId String?
  /** Публичные ссылки организации для сайта. */
  websiteUrl String?
  socialYoutubeUrl String?
  socialInstagramUrl String?
  socialTelegramUrl String?
  socialMaxUrl String?
  /** Публичный логотип организации (шапка/подвал сайта). */
  publicLogoUrl String?
  /** Публичный favicon (иконка вкладки браузера). */
  publicFaviconUrl String?
  /** Основной акцент публичных страниц. HEX #RRGGBB. */
  publicAccentPrimary String @default("#123c67")
  /** Вторичный акцент публичных страниц. HEX #RRGGBB. */
  publicAccentSecondary String @default("#c80a48")
  /** Режим темы публичной части: light | dark | system. */
  publicThemeMode String @default("system")
  /** Короткий слоган в шапке/подвале публичного сайта. */
  publicTagline String?
  /** Публичное отображаемое название организации (если отличается от системного). */
  publicOrganizationDisplayName String?
  /** Контакты для публичного футера. */
  publicContactPhone String?
  publicContactEmail String?
  publicContactAddress String?
  publicContactHours String?
  /** SEO-настройки публичной части. */
  publicSeoTitle String?
  publicSeoDescription String?
  publicOgImageUrl String?
  /** Дефолтный раздел публички для переходов из логотипа/бренда. */
  publicDefaultLanding String @default("tournaments")
  /** Порядок вкладок турнира: table,chessboard,progress,playoff */
  publicTournamentTabsOrder String @default("table,chessboard,progress,playoff")
  /** Отображение отдельных публичных блоков. */
  publicShowLeaderInFacts Boolean @default(true)
  publicShowTopStats Boolean @default(true)
  publicShowNewsInSidebar Boolean @default(true)
  showWebsiteLink Boolean @default(true)
  showSocialYoutubeLink Boolean @default(true)
  showSocialInstagramLink Boolean @default(true)
  showSocialTelegramLink Boolean @default(true)
  showSocialMaxLink Boolean @default(true)
  /** Общие настройки админ-панели (тема, локаль, акцент) для всех пользователей организации. */
  adminUiSettings Json?

  users       User[]
  tournaments Tournament[]
  teams       Team[]
  teamCategories TeamCategory[]
  teamCategoryRules TeamCategoryRule[]
  refreshTokens RefreshToken[]
  matches     Match[]
  tournamentTeams TournamentTeam[]
  tournamentMembers TournamentMember[]
  tournamentGroups TournamentGroup[]
  tournamentTableRows TournamentTableRow[]
  players     Player[]
  tournamentNews TournamentNews[]
  newsTags    NewsTag[]
  tournamentNewsTags TournamentNewsTag[]
  tournamentGalleryImages TournamentGalleryImage[]
  stadiums    Stadium[]
  referees    Referee[]
  refereeCategories RefereeCategory[]
  refereePositions  RefereePosition[]
  managementMembers   ManagementMember[]
  competitions        Competition[]
  seasons             Season[]
  ageGroups           AgeGroup[]
  regions             Region[]
  referenceDocuments  ReferenceDocument[]
  tournamentReferees TournamentReferee[]
  protocolEventTypes  ProtocolEventType[]
  matchScheduleReasons MatchScheduleReason[]

  @@index([subscriptionEndsAt])
}

/// Расширяемые подписи событий протокола; `mapsToType` хранит семантику для логики и статистики.
model ProtocolEventType {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  mapsToType  MatchEventType
  note        String?
  sortOrder   Int            @default(0)
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matchEvents MatchEvent[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

/// Причины переноса / отмены матча (журналирование смены времени и статуса).
model MatchScheduleReason {
  id        String                   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  note      String?
  /// Для каких сценариев доступна запись: перенос, отмена или оба.
  scope     MatchScheduleReasonScope @default(BOTH)
  sortOrder Int                      @default(0)
  active    Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matches Match[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

enum MatchScheduleReasonScope {
  POSTPONE
  CANCEL
  BOTH
}

/// Возрастная группа / дивизион (U12, взрослые и т.д.) — справочник тенанта.
model AgeGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  /** Короткая подпись для бейджей: U12, ст.возраст */
  shortLabel  String?
  code        String?
  note        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teams       Team[]
  tournaments Tournament[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

/// Регион / территория для команд и площадок — справочник тенанта.
model Region {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  note      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teams    Team[]
  stadiums Stadium[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

/// Вид / название соревнования в справочнике тенанта (чемпионат, кубок и т.д.).
model Competition {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  note      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournaments Tournament[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

/// Сезон / игровой год (справочник тенанта).
model Season {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  note      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournaments Tournament[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

/// Документ (регламент, положение): ссылка и примечание; файл — по URL или позже через загрузку.
model ReferenceDocument {
  id        String   @id @default(cuid())
  tenantId  String
  /// null = общий документ тенанта; not null = документ конкретного турнира.
  tournamentId String?
  title     String
  code      String?
  url       String?
  note      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tenantId, sortOrder])
  @@index([tenantId, tournamentId, sortOrder])
}

/// Руководящий состав организации тенанта (админка; публичный вывод — по желанию позже).
model ManagementMember {
  id        String   @id @default(cuid())
  tenantId  String
  lastName  String
  firstName String
  /** Должность: председатель, член совета и т.д. */
  title     String
  phone     String?
  email     String?
  note      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sortOrder])
  @@index([tenantId, lastName, firstName])
}

/// Позиция судьи на матче (главный, линейный и т.д.) — справочник тенанта.
model RefereePosition {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referees Referee[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

/// Категория / разряд судьи (справочник тенанта).
model RefereeCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referees Referee[]

  @@index([tenantId, sortOrder])
  @@index([tenantId, name])
}

model Stadium {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  city      String?
  regionId  String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  region      Region?      @relation(fields: [regionId], references: [id], onDelete: SetNull)
  tournaments Tournament[]

  @@index([tenantId, name])
  @@index([tenantId, regionId])
}

/// Судья из справочника (не учётная запись User).
model Referee {
  id                  String   @id @default(cuid())
  tenantId            String
  firstName           String
  lastName            String
  phone               String?
  note                String?
  refereeCategoryId   String?
  refereePositionId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refereeCategory     RefereeCategory?    @relation(fields: [refereeCategoryId], references: [id], onDelete: SetNull)
  refereePosition     RefereePosition?    @relation(fields: [refereePositionId], references: [id], onDelete: SetNull)
  tournamentReferees  TournamentReferee[]

  @@index([tenantId, lastName, firstName])
  @@index([tenantId, refereeCategoryId])
  @@index([tenantId, refereePositionId])
}

model TournamentReferee {
  id           String   @id @default(cuid())
  tenantId     String
  tournamentId String
  refereeId    String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  referee    Referee    @relation(fields: [refereeId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, refereeId])
  @@index([tenantId, tournamentId])
}

/// Тарифы: FREE + 4 платных (Любительская / Премьер-лига / Лига чемпионов / Чемпионат мира).
enum SubscriptionPlan {
  FREE
  AMATEUR
  PREMIER
  CHAMPIONS
  WORLD_CUP
}

enum SubscriptionStatus {
  NONE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

model User {
  id          String   @id @default(cuid())
  /** Обязателен при регистрации организации; при создании пользователя админом может быть пустым. */
  email       String?  @unique
  username    String
  password    String
  name        String
  lastName    String   @default("")
  role        UserRole @default(USER)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blocked     Boolean  @default(false)

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tournamentMemberships TournamentMember[]
  /** Турниры, созданные этим пользователем (админ турнира видит только их). */
  createdTournaments Tournament[] @relation("TournamentCreator")
  teamAdminOf TeamAdmin[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, username])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  category    String?
  logoUrl     String?
  /// Цвет событий турнира в админ-календаре (#RRGGBB). null — стандартный цвет темы.
  calendarColor String?
  format      TournamentFormat @default(SINGLE_GROUP)
  groupCount  Int      @default(1)
  playoffQualifiersPerGroup Int @default(2)
  startsAt    DateTime?
  endsAt      DateTime?
  status      TournamentStatus @default(DRAFT)
  /// Показывать турнир на публичном сайте (страницы по tid, таблица и т.д.). Независимо от статуса жизненного цикла.
  published   Boolean  @default(false)
  intervalDays Int     @default(7)
  allowedDays  Int[]   @default([])
  roundRobinCycles     Int @default(1)
  matchDurationMinutes Int @default(50)
  matchBreakMinutes    Int @default(10)
  simultaneousMatches  Int @default(1)
  dayStartTimeDefault  String @default("12:00") // HH:mm
  dayStartTimeOverrides Json?                   // { "0": "10:00", "6": "12:00" }
  minTeams    Int      @default(2)
  pointsWin   Int      @default(3)
  pointsDraw  Int      @default(1)
  pointsLoss  Int      @default(0)
  tenantId    String
  /** Кто создал турнир в админке; для роли TOURNAMENT_ADMIN — граница доступа. */
  createdByUserId String?
  /** Игровой сезон из справочника (опционально). */
  seasonId       String?
  /** Тип соревнования из справочника: чемпионат, кубок и т.д. (опционально). */
  competitionId  String?
  /** Возрастная группа турнира из справочника (опционально). */
  ageGroupId     String?
  stadiumId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  createdBy   User?       @relation("TournamentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  season      Season?     @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  competition Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  ageGroup    AgeGroup?   @relation(fields: [ageGroupId], references: [id], onDelete: SetNull)
  stadium     Stadium?    @relation(fields: [stadiumId], references: [id], onDelete: SetNull)
  teams       Team[]              // legacy связь (пока не выпиливаем)
  tournamentTeams TournamentTeam[]
  groups      TournamentGroup[]
  members     TournamentMember[]
  matches     Match[]
  news        TournamentNews[]
  galleryImages TournamentGalleryImage[]
  tableRows   TournamentTableRow[]
  tournamentReferees TournamentReferee[]
  referenceDocuments ReferenceDocument[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, createdByUserId])
  @@index([tenantId, seasonId])
  @@index([tenantId, competitionId])
  @@index([tenantId, ageGroupId])
  @@index([tenantId, stadiumId])
}

model TournamentNews {
  id           String   @id @default(cuid())
  tenantId     String
  /** null — черновик без привязки; для публикации обязателен (см. сервис). */
  tournamentId String?
  title        String
  slug         String
  excerpt      String?
  content      String?
  coverImageUrl String?
  section      NewsSection @default(ANNOUNCEMENT)
  published    Boolean  @default(false)
  publishedAt  DateTime?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  newsTags     TournamentNewsTag[]

  @@index([tenantId, tournamentId, published, publishedAt])
  @@index([tenantId, published, publishedAt])
}

model NewsTag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  taggedNews TournamentNewsTag[]

  @@unique([tenantId, slug])
  @@index([tenantId, sortOrder])
}

model TournamentNewsTag {
  id        String   @id @default(cuid())
  tenantId  String
  newsId    String
  tagId     String
  createdAt DateTime @default(now())

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  news   TournamentNews @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag    NewsTag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([newsId, tagId])
  @@index([tenantId, newsId])
  @@index([tenantId, tagId])
}

/// Фото турнира: множественная загрузка, порядок, подпись.
model TournamentGalleryImage {
  id           String   @id @default(cuid())
  tenantId     String
  tournamentId String
  imageUrl     String
  caption      String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tenantId, tournamentId, sortOrder])
  @@index([tenantId, createdAt])
}

model Team {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  // Base strength rating for seed heuristics (1..5), used as default in tournaments.
  rating       Int          @default(3)
  slug         String?      // "spartak-2008" для URL (позже сделаем NOT NULL)
  logoUrl      String?
  category     String?      // "U12", "Adult", "Amateur"
  ageGroupId   String?
  regionId     String?
  coachName    String?
  coachPhone   String?
  coachEmail   String?
  contactName  String?
  contactPhone String?
  description  String?

  // legacy поле (пока не выпиливаем)
  tournamentId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  tournament   Tournament?  @relation(fields: [tournamentId], references: [id])
  ageGroup     AgeGroup?    @relation(fields: [ageGroupId], references: [id], onDelete: SetNull)
  region       Region?      @relation(fields: [regionId], references: [id], onDelete: SetNull)
  admins       TeamAdmin[]
  players      TeamPlayer[]
  tournamentTeams TournamentTeam[]
  homeMatches  Match[]      @relation("HomeTeam")
  awayMatches  Match[]      @relation("AwayTeam")
  tableRows    TournamentTableRow[]

  @@unique([tenantId, slug])
  @@index([tenantId, name])
  @@index([tenantId, ageGroupId])
  @@index([tenantId, regionId])
}

model TeamCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String?
  /// Minimal allowed birth year for the category (e.g. 2018).
  /// Players born earlier than this year are not allowed.
  minBirthYear Int?
  /// Maximal allowed birth year for the category.
  /// Players born later than this year are not allowed.
  maxBirthYear Int?
  /// If true, player must have birthDate to be added into team of this category.
  requireBirthDate Boolean @default(false)
  /// Allowed player genders for this category; empty array means "any".
  allowedGenders PlayerGender[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules TeamCategoryRule[]

  @@unique([tenantId, name])
  @@index([tenantId, name])
}

model TeamCategoryRule {
  id         String   @id @default(cuid())
  tenantId   String
  categoryId String
  type       TeamCategoryType
  minBirthYear Int?
  maxBirthYear Int?
  requireBirthDate Boolean @default(false)
  allowedGenders PlayerGender[] @default([])
  createdAt  DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category TeamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([tenantId, categoryId])
}

model TournamentTeam {
  id           String   @id @default(cuid())
  tenantId     String
  tournamentId String
  teamId       String
  groupId      String?
  // Rating of the team inside this tournament context (1..5).
  // Used for better scheduling: strong teams are placed to meet later.
  rating      Int      @default(3)
  /// Order within the group (0 = first in admin «Составы» column); tie-breaker in standings when stats match.
  groupSortOrder Int   @default(0)
  createdAt    DateTime @default(now())

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  group        TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, teamId])
  @@index([tenantId, tournamentId])
  @@index([tournamentId, groupId])
}

model TournamentGroup {
  id           String   @id @default(cuid())
  tenantId     String
  tournamentId String
  name         String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams        TournamentTeam[]
  matches      Match[]

  @@unique([tournamentId, name])
  @@index([tenantId, tournamentId])
}

model TournamentMember {
  id           String   @id @default(cuid())
  tenantId     String
  tournamentId String
  userId       String
  role         TournamentMemberRole
  createdAt    DateTime @default(now())

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId, role])
  @@index([tenantId, tournamentId])
}

model Match {
  id           String       @id @default(cuid())
  tenantId     String
  /** null — матч создан без турнира (общий список), позже можно прикрепить к MANUAL. */
  tournamentId String?
  homeTeamId   String
  awayTeamId   String
  stage        MatchStage   @default(GROUP)
  roundNumber  Int          @default(1)
  groupId      String?
  playoffRound PlayoffRound?
  startTime    DateTime
  status       MatchStatus  @default(SCHEDULED)
  homeScore    Int?
  awayScore    Int?
  /** Последняя зафиксированная причина переноса или отмены (из справочника). */
  scheduleChangeReasonId String?
  scheduleChangeNote       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  tournament   Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  homeTeam     Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  group        TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  scheduleChangeReason MatchScheduleReason? @relation(fields: [scheduleChangeReasonId], references: [id], onDelete: SetNull)
  events       MatchEvent[]

  @@index([tournamentId, startTime])
  @@index([tournamentId, status, startTime])
  @@index([tenantId, tournamentId])
  @@index([scheduleChangeReasonId])
}

model MatchEvent {
  id        String        @id @default(cuid())
  matchId   String
  type      MatchEventType
  minute    Int?
  playerId  String?
  teamSide  MatchTeamSide?
  payload   Json?
  protocolEventTypeId String?
  createdAt DateTime      @default(now())

  match              Match              @relation(fields: [matchId], references: [id])
  protocolEventType  ProtocolEventType? @relation(fields: [protocolEventTypeId], references: [id], onDelete: SetNull)

  @@index([protocolEventTypeId])
}

model TournamentTableRow {
  id           String   @id @default(cuid())
  tenantId     String
  tournamentId String
  teamId       String

  position     Int
  played       Int
  wins         Int
  draws        Int
  losses       Int
  goalsFor     Int
  goalsAgainst Int
  goalDiff     Int
  points       Int

  updatedAt    DateTime @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tenantId, tournamentId])
  @@index([tournamentId, position])
  @@index([tournamentId, updatedAt])
}

model TeamAdmin {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamPlayer {
  id           String   @id @default(cuid())
  teamId       String
  playerId     String
  jerseyNumber Int?
  position     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@unique([playerId])
  @@index([teamId, isActive])
  @@index([playerId])
}

model Player {
  id        String   @id @default(cuid())
  tenantId  String
  firstName String
  lastName  String
  birthDate DateTime?
  gender    PlayerGender?
  bioNumber String?
  biography String?
  position  String?
  phone     String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  teamPlayers TeamPlayer[]

  @@index([tenantId, firstName, lastName])
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  TOURNAMENT_ADMIN
  TEAM_ADMIN
  MODERATOR
  USER
  REFEREE
}

/// Формат турнира. MANUAL — только ручные матчи, без автогенерации расписания.
enum TournamentFormat {
  SINGLE_GROUP
  GROUPS_2
  GROUPS_3
  GROUPS_4
  PLAYOFF
  GROUPS_PLUS_PLAYOFF
  MANUAL
}

enum TournamentStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum NewsSection {
  ANNOUNCEMENT
  REPORT
  INTERVIEW
  OFFICIAL
  MEDIA
}

enum TournamentMemberRole {
  TOURNAMENT_ADMIN
  MODERATOR
  REFEREE
}

enum PlayerGender {
  MALE
  FEMALE
}

enum TeamCategoryType {
  AGE
  GENDER
}

enum MatchTeamSide {
  HOME
  AWAY
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELED
  PLAYED
}

enum MatchEventType {
  GOAL
  CARD
  SUBSTITUTION
  CUSTOM
}

enum MatchStage {
  GROUP
  PLAYOFF
}

/// Стадии плей-офф (в т.ч. ROUND_OF_16 / QUARTERFINAL для больших сеток)
enum PlayoffRound {
  SEMIFINAL
  FINAL
  THIRD_PLACE
  ROUND_OF_16
  QUARTERFINAL
}
