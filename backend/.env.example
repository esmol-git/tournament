# Database, JWT, etc. — см. ваш локальный .env

# S3-совместимое хранилище (MinIO, AWS S3, …)
S3_ENDPOINT=http://127.0.0.1:9000
# Имя бакета должно существовать в MinIO, либо включи автосоздание:
S3_BUCKET=tournament-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Опционально; по умолчанию us-east-1 (для MinIO обычно ок)
# S3_REGION=us-east-1
# Вне production бакет создаётся сам, если его нет. В production задай явно true или создай бакет вручную.
# S3_CREATE_BUCKET_IF_MISSING=false

# Публичное чтение по прямой ссылке. Не задано: для MinIO/IP — вкл., для *.amazonaws.com — выкл.
# S3_SET_PUBLIC_READ_POLICY=false

# ACL на объект: по умолчанию public-read. Если PutObject падает — S3_OBJECT_ACL=none
# S3_OBJECT_ACL=none

# Не называй бакет так же, как префикс папки в ключе (раньше было images/ → при бакете images получалось /images/images/...)

# Качество WebP при загрузке картинок (POST /upload), 1–100. По умолчанию 85.
# UPLOAD_WEBP_QUALITY=85
