# Скопируйте в `.env` в этой же папке:  cp .env.example .env
# Важно: Expo подхватывает только файл `.env`, не `.env.example`.
# Иначе под кнопкой входа останется дефолт http://127.0.0.1:4000.
# После изменения `.env` перезапустите `npm start`.

# Локальный backend (эмулятор / тот же Mac):
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# Продакшен API (как NUXT_PUBLIC_API_BASE у веб-фронта):
EXPO_PUBLIC_API_BASE_URL=https://api.tournament-platform.ru
